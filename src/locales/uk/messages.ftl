start-welcome = Вітаємо у <b>EmojiStickerCopyBot</b>!
    Я допоможу тобі клонувати та керувати наборами стікерів.
    Використовуй /packs щоб побачити доступні опції.

packs-menu = 🏷 <b>Керування стікерпаками</b>
    Обери, що ти хочеш зробити:

btn-create-regular = 🖼 Звичайний пак
btn-create-emoji = 😀 Емодзі пак
btn-create-animated = ✨ Анімований пак
btn-create-video = 🎥 Відео пак
btn-clone-pack = 🔄 Клонувати пак
btn-my-packs = 📚 Мої паки
btn-cancel = ❌ Скасувати

prompt-copy = Будь ласка, надішли мені <b>стікер</b> з паку, який хочеш клонувати, або <b>посилання</b> на пак.
prompt-title = Введи <b>назву</b> для свого нового стікерпаку:
prompt-name = Введи <b>коротку назву</b> для посилання (тільки латиниця та цифри):
prompt-media = Чудово! Тепер надсилай <b>фото або стікери</b>, щоб додати їх до паку "{$title}".
    Коли закінчиш, натисни "Готово".

err-invalid-name = ❌ Некоректна коротка назва. Використовуй лише латиницю та цифри.
err-name-exists = ❌ Назва <code>{$name}</code> вже зайнята. Обери іншу.
err-generic = ❌ Сталася помилка: {$error}

processing-item = ⏳ Обробка...
item-added = ✅ Додано! Всього стікерів: {$count}
copy-started = ⏳ Клонування паку "{$title}" розпочато...
create-success = ✅ Пак "{$title}" успішно створено! Посилання: <code>https://t.me/addstickers/{$name}</code>
wait-processing = ⏳ Зачекай, обробляється ще {$count} об'єктів...
btn-open-pack = 📂 Відкрити пак
btn-done = ✅ Готово
btn-copy-to = 📥 Копіювати в...
btn-copy-mode = ⚡ Режим копіювання

msg-what-to-do = 🧐 Що зробити з цим об'єктом?
msg-select-target = 🎯 Обери пак, у який додати цей стікер:
msg-copy-mode-on = ⚡ <b>Режим копіювання активовано!</b>
    Тепер всі надіслані стікери/фото будуть додаватись у пак: <b>{$title}</b>
    
    <i>Натисніть "Вимкнути", щоб вийти з цього режиму.</i>
msg-copy-mode-off = ❌ Режим копіювання вимкнено.
btn-disable = 🛑 Вимкнути
msg-no-packs = ❌ У тебе ще немає створених паків. Спочатку створи один!
btn-back = 🔙 Назад
btn-copy-one = 📥 Копіювати цей
btn-clone-all = 🔄 Клонувати весь пак

msg-what-to-do = 🧐 Що зробити з цим об'єктом?
msg-select-format = ⚙️ <b>Обери формат:</b>
    Як ми маємо його зберегти?

btn-fmt-original = 🖼 Як є (Стікер)
btn-fmt-emoji = 😀 В емодзі
btn-fmt-emoji-nobg = 🌫 Емодзі (без фону)

msg-no-packs-create = 🧐 У тебе ще немає паків. Давай створимо твій перший пак прямо зараз!
    Який тип паку хочеш?

btn-create-first-regular = 🖼 Створити Пак Стікерів
btn-create-first-emoji = 😀 Створити Пак Емодзі

msg-select-target = 🎯 Обери пак для додавання:
